---
import ProgrammingLayout from "../../layouts/ProgrammingLayout.astro";
import { getCollection, render } from "astro:content";
import Star from "@lucide/astro/icons/star";
import Briefcase from "@lucide/astro/icons/briefcase";
import ProjectTile from "../../components/programming/ProjectTile.astro";
import WorkExperienceCard from "../../components/programming/WorkExperienceCard.astro";

const projects = await getCollection("programming");
const workExperience = await getCollection("programmingExperience");
const sortedExperience = workExperience.sort(
  (a, b) => a.data.order - b.data.order,
);
const sorted = projects.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

