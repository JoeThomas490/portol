  <section class="pb-12">
    <div class="flex flex-row gap-x-2 items-center mb-4">
      <h2 class="text-2xl font-bold font-heading">Projects</h2>
      <Star stroke-width={2} class="w-6 h-6 text-(--color-accent)" />
    </div>
    <div
      class="w-full grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 gap-4 project-group"
    >
      {
        sorted.map((project) => (
          <ProjectTile
            href={`/programming/${project.id}`}
            title={project.data.title}
            description={project.data.description}
            heroImage={project.data.heroImage}
            tags={project.data.tags}
          />
        ))
      }
    </div>
  </section>
  <!-- Experience -->
  <section class="mb-12">
    <div class="flex flex-row gap-x-2 items-center mb-4">
      <h2 class="text-2xl font-bold font-heading">Experience</h2>
      <Briefcase stroke-width={2} class="w-6 h-6 text-(--color-accent)" />
    </div>
    <div class="flex flex-col gap-4">
      {
        sortedExperience.map(async (exp) => {
          const { Content } = await render(exp);
          return (
            <WorkExperienceCard
              role={exp.data.role}
              studio={exp.data.studio}
              logo={exp.data.logo}
              dateRange={exp.data.dateRange}
              website={exp.data.website}
              active={exp.data.active}
            >
              <Content />
            </WorkExperienceCard>
          );
        })
      }
    </div>
  </section>
</ProgrammingLayout>

<style is:global>
  .project-group:has(.project-tile:hover) .project-tile:not(:hover) {
    opacity: 0.5;
    filter: brightness(0.6);
    transition:
      opacity 0.3s ease,
      filter 0.3s ease;
  }

  .project-tile {
    transition:
      opacity 0.3s ease,
      filter 0.3s ease;
  }
</style>
