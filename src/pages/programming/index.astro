---
import ProgrammingLayout from "../../layouts/ProgrammingLayout.astro";
import DeveloperLayout from "../../layouts/DeveloperLayout.astro";
import { getCollection } from "astro:content";
import Download from "@lucide/astro/icons/download";

const projects = await getCollection("programming");
const sorted = projects.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<DeveloperLayout mode="programming">
  <section
    class="flex flex-col gap-y-4 p-8 ring-0 ring-purple-500/50 rounded-2xl mt-12 rounded-b-none bg-linear-to-b from-purple-800/60 via-purple-800/20 to-transparent"
  >
    <!-- Hero -->
    <div>
      <div class="w-full flex flex-row gap-8">
        <img
          src="https://assets.joenoseph.co.uk/me/me_002.jpg"
          alt="Joe Thomas"
          class="h-40 w-40 object-cover rounded-full ring-4 ring-white/70"
        />
        <div class="h-full flex-2 flex-col gap-y-2 w-full">
          <h1 class="text-4xl md:text-5xl font-bold">
            Hey, I'm <span class="text-purple-500">Joe Thomas!</span> 👋
          </h1>
          <p class="text-lg md:text-xl mt-4">
            I'm a co-founder + Technical Lead of <span
              class="underline decoration-wavy decoration-purple-500 decoration-2"
              ><a href="/programming/labbo">Labbo</a></span
            >, a Creative Software Engineer and UI Technical Artist.
          </p>
          <p class="text-sm mt-4 group">
            <a
              href="https://www.google.com/maps/place/Liverpool,+UK"
              target="_blank"
              rel="noopener noreferrer"
              ><span
                class="group-hover:animate-bounce transition-all duration-200"
                >📍</span
              > Liverpool, UK</a
            >
          </p>
        </div>
      </div>
    </div>
    <!-- Socials -->
    <div>
      <div class="w-full flex flex-row gap-2">
        <a
          href="https://github.com/joethomas490"
          target="_blank"
          rel="noopener noreferrer"
          class="w-12 h-12 rounded-lg bg-(--color-muted) hover:bg-(--color-border) transition-colors duration-200 flex items-center justify-center"
          aria-label="GitHub"
        >
          <img
            src="https://cdn.simpleicons.org/github/ffffff"
            alt="GitHub"
            class="w-5 h-5"
          />
        </a>
        <a
          href="https://www.linkedin.com/in/jmthomas96/"
          target="_blank"
          rel="noopener noreferrer"
          class="w-12 h-12 rounded-lg bg-(--color-muted) hover:bg-(--color-border) transition-colors duration-200 flex items-center justify-center"
          aria-label="LinkedIn"
        >
          <img src="public/icons/linkedin.png" alt="LinkedIn" class="w-5 h-5" />
        </a>
        <a
          href="https://instagram.com/joenoseph"
          target="_blank"
          rel="noopener noreferrer"
          class="w-12 h-12 rounded-lg bg-(--color-muted) hover:bg-(--color-border) transition-colors duration-200 flex items-center justify-center"
          aria-label="Instagram"
        >
          <img
            src="https://cdn.simpleicons.org/instagram/ffffff"
            alt="Instagram"
            class="w-5 h-5"
          />
        </a>
        <a
          href="mailto:joe_thomas490@hotmail.com"
          class="w-12 h-12 rounded-lg bg-(--color-muted) hover:bg-(--color-border) transition-colors duration-200 flex items-center justify-center"
          aria-label="Email"
        >
          <img
            src="https://cdn.simpleicons.org/gmail/ffffff"
            alt="Email"
            class="w-5 h-5"
          />
        </a>
        <a
          href="https://assets.joenoseph.co.uk/cv/cv.pdf"
          download
          class="flex-1 h-12 rounded-lg bg-(--color-muted) hover:bg-(--color-border) transition-colors duration-200 flex items-center justify-center gap-2 font-medium text-sm"
          aria-label="Download CV"
        >
          <Download class="w-5 h-5" />
          Download CV
        </a>
      </div>
    </div>
  </section>
  <section class="py-12">
    <h2 class="text-2xl font-bold mb-4">Projects</h2>
    <div class="w-full grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 gap-4">
      {
        sorted.map((project) => (
          <a
            href={`/programming/${project.id}`}
            class="project-tile group relative aspect-square overflow-hidden bg-(--color-muted) rounded-2xl"
          >
            {project.data.heroImage && (
              <img
                src={project.data.heroImage}
                alt={project.data.title}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 ease-[cubic-bezier(0.25,0,0.2,1)] group-hover:scale-105"
                loading="lazy"
              />
            )}
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/50 transition-colors duration-300" />
            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <h2
                class="text-white text-xl md:text-2xl font-bold tracking-tight text-center px-4 drop-shadow-[0_2px_8px_rgba(0,0,0,0.6)]"
                style="font-family: var(--font-heading);"
              >
                {project.data.title}
              </h2>
            </div>
            {project.data.tools && project.data.tools.length > 0 && (
              <div class="absolute bottom-3 left-3 right-3 flex flex-wrap gap-1.5 z-10">
                {project.data.tools.slice(0, 3).map((tool: string) => (
                  <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-black/50 text-white/90 backdrop-blur-sm border border-white/10">
                    {tool}
                  </span>
                ))}
              </div>
            )}
          </a>
        ))
      }
    </div>
  </section>
</DeveloperLayout>
