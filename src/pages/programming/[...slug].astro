---
import { getCollection, render } from "astro:content";
import ExternalLink from "@lucide/astro/icons/external-link";
import Tag from "@lucide/astro/icons/tag";
import DeveloperLayout from "../../layouts/DeveloperLayout.astro";
import Button from "../../components/programming/Button.astro";

export async function getStaticPaths() {
  const projects = await getCollection("programming");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const meta = [
  { label: "Role", value: project.data.role },
  { label: "Studio", value: project.data.studio },
  { label: "Date", value: project.data.dateRange },
  { label: "Platform", value: project.data.platform },
].filter((m) => m.value);
---

<DeveloperLayout mode="programming">
  <article class="flex flex-col rounded-2xl my-12 bg-black/20 backdrop-blur-sm">
    {
      project.data.heroImage && (
        <div class="h-96 md:h-fit w-full p-4 aspect-21/9 overflow-hidden mb-10">
          <img
            src={project.data.heroImage}
            alt={project.data.title}
            class="w-full h-full object-cover rounded-lg"
          />
        </div>
      )
    }

    <div class="p-8 pt-2">
      <div class="flex items-start justify-between gap-4 mb-6">
        <h1 class="text-3xl md:text-5xl font-bold tracking-tight font-heading">
          {project.data.title}
        </h1>
        <div class="flex gap-3 shrink-0 pt-2">
          {
            project.data.repo && (
              <Button
                href={project.data.repo}
                label="Repository"
                icon="https://cdn.simpleicons.org/github/ffffff"
                class="gap-2"
              >
                GitHub <ExternalLink size={14} />
              </Button>
            )
          }
          {
            project.data.url && (
              <Button href={project.data.url} label="Live">
                <ExternalLink size={14} />
                Live
              </Button>
            )
          }
        </div>
      </div>

      {
        meta.length > 0 && (
          <dl class="space-y-1 text-sm" style="color: var(--color-accent);">
            {meta.map(({ label, value }) => (
              <div class="flex gap-2">
                <dt class="font-semibold" style="color: var(--color-text);">
                  {label}:
                </dt>
                <dd>{value}</dd>
              </div>
            ))}
          </dl>
        )
      }

      {
        project.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            <span class="text-sm text-(--color-text-muted) flex flex-row items-center gap-1">
              <Tag class="w-4 h-4" />
            </span>
            {project.data.tags.map((tag: string) => (
              <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-purple-500/10 text-purple-400 border border-purple-500/20">
                {tag.toLowerCase()}
              </span>
            ))}
          </div>
        )
      }
    </div>

    <div class="project-prose p-8 pt-2">
      <Content />
    </div>

    <div class="py-8" style="border-top: 1px solid var(--color-border);">
      <a
        href="/programming"
        class="text-sm px-4 py-2 rounded-lg transition-colors duration-200"
        style="color: var(--color-accent);"
      >
        &larr; All Projects
      </a>
    </div>
  </article>
</DeveloperLayout>

<style>
  .project-prose :global(h2) {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .project-prose :global(h3) {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .project-prose :global(p) {
    color: var(--color-accent);
    line-height: 1.75;
    margin-bottom: 1.25rem;
    max-width: 72ch;
  }

  .project-prose :global(ul),
  .project-prose :global(ol) {
    color: var(--color-accent);
    line-height: 1.75;
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
    max-width: 72ch;
  }

  .project-prose :global(li) {
    margin-bottom: 0.25rem;
  }

  .project-prose :global(ul) {
    list-style-type: disc;
  }

  .project-prose :global(ol) {
    list-style-type: decimal;
  }

  .project-prose :global(img) {
    width: 100%;
    border-radius: 0.5rem;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .project-prose :global(video) {
    width: 100%;
    border-radius: 0.5rem;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .project-prose :global(a) {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .project-prose :global(a:hover) {
    opacity: 0.7;
  }

  .project-prose :global(blockquote) {
    border-left: 3px solid var(--color-border);
    padding-left: 1rem;
    color: var(--color-accent);
    font-style: italic;
    margin: 1.5rem 0;
  }

  .project-prose :global(code) {
    font-family: var(--font-heading);
    font-size: 0.875em;
    background-color: var(--color-muted);
    padding: 0.15em 0.4em;
    border-radius: 0.25rem;
  }

  .project-prose :global(pre) {
    background-color: var(--color-muted);
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .project-prose :global(pre code) {
    background: none;
    padding: 0;
  }

  .project-prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }
</style>
