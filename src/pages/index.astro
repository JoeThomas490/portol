---
import { ViewTransitions } from "astro:transitions";
import Camera from "@lucide/astro/icons/camera";
import CodeXml from "@lucide/astro/icons/code-xml";
import Palette from "@lucide/astro/icons/palette";

const modes = [
  {
    name: "Photography",
    href: "/photography",
    bg: "bg-stone-100",
    text: "text-stone-900",
    hoverBg: "hover:bg-stone-200",
    accent: "bg-stone-900",
    image: "https://assets.joenoseph.co.uk/photography/header.webp",
    icon: Camera,
  },
  {
    name: "Programming",
    href: "/programming",
    bg: "bg-neutral-900",
    text: "text-white",
    hoverBg: "hover:bg-neutral-800",
    accent: "bg-white",
    image: "https://assets.joenoseph.co.uk/programming/header.webp",
    icon: CodeXml,
  },
  // {
  //   name: "Art",
  //   href: null,
  //   bg: "bg-amber-50",
  //   text: "text-amber-900",
  //   hoverBg: "hover:bg-amber-100",
  //   accent: "bg-amber-900",
  //   image:
  //     "https://images.unsplash.com/photo-1579783902614-a3fb3927b6a5?w=800&q=80",
  //   icon: Palette,
  // },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Joe Thomas" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Portfolio | Joe Thomas</title>
    <ViewTransitions />
  </head>
  <body class="h-dvh flex flex-col overflow-hidden bg-neutral-950">
    <nav class="fixed top-0 left-0 right-0 z-50 p-6">
      <div class="flex items-center justify-between">
        <div class="flex flex-col items-start gap-0">
          <span class="text-lg font-bold tracking-tight text-white">
            Joe Thomas
          </span>
        </div>
      </div>
    </nav>

    <div class="flex flex-1 min-h-0">
      {
        modes.map((mode) => {
          const Tag = mode.href ? "a" : "div";
          const Icon = mode.icon;
          return (
            <Tag
              href={mode.href}
              class:list={[
                "bookshelf-slice group relative flex flex-col items-center justify-center gap-4 overflow-hidden",
                "transition-all duration-500 ease-[cubic-bezier(0.25,0,0.2,1)]",
                "border-r border-neutral-800 last:border-r-0",
                mode.href ? "cursor-pointer" : "cursor-default",
                mode.bg,
                mode.hoverBg,
              ]}
            >
              <div
                class="absolute inset-0 bg-cover bg-center grayscale group-hover:grayscale-0 transition-[filter] duration-700 ease-[cubic-bezier(0.25,0,0.2,1)]"
                style={`background-image: url('${mode.image}');`}
              />
              <div class="absolute inset-0 bg-black/40 group-hover:bg-black/30 transition-colors duration-500" />

              <span class="relative z-10 text-white drop-shadow-[0_2px_8px_rgba(0,0,0,0.5)] opacity-60 group-hover:opacity-100 transition-opacity duration-500">
                <Icon size={32} />
              </span>

              <span
                class:list={[
                  "writing-vertical relative z-10 text-4xl md:text-6xl font-black tracking-wide select-none",
                  "text-white drop-shadow-[0_2px_8px_rgba(0,0,0,0.5)]",
                  "transition-opacity duration-500",
                ]}
              >
                {mode.name}
              </span>

              <span class="absolute z-10 bottom-8 left-1/2 -translate-x-1/2 w-1.5 h-1.5 rounded-full bg-white opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
            </Tag>
          );
        })
      }
    </div>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";

  .writing-vertical {
    writing-mode: vertical-lr;
    text-orientation: mixed;
    transform: rotate(180deg);
  }

  .bookshelf-slice {
    flex: 1 1 0%;
  }

  .bookshelf-slice:hover {
    flex: 3 1 0%;
  }
</style>
