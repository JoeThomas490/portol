---
import { ViewTransitions } from "astro:transitions";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Portol — Joe Thomas" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Portol</title>
    <ViewTransitions />
  </head>
  <body class="min-h-dvh flex items-center justify-center bg-neutral-100">
    <div class="flex flex-col items-center gap-12">
      <h1
        class="text-5xl md:text-7xl font-bold tracking-tighter text-neutral-900"
      >
        Joenoseph
      </h1>
      <p class="text-lg text-neutral-500 max-w-md text-center">
        Choose a mode to explore
      </p>
      <div class="flex gap-6">
        <a
          href="/photography"
          class="group relative flex flex-col items-center gap-3 px-10 py-8 rounded-2xl border border-neutral-200 bg-white hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
        >
          <span
            class="w-6 h-6 rounded-full bg-white border-2 border-neutral-300 group-hover:border-neutral-900 transition-colors"
          ></span>
          <span class="text-lg font-medium text-neutral-900">Photography</span>
        </a>
        <a
          href="/programming"
          class="group relative flex flex-col items-center gap-3 px-10 py-8 rounded-2xl border border-neutral-700 bg-neutral-900 hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
        >
          <span
            class="w-6 h-6 rounded-full bg-neutral-900 border-2 border-neutral-600 group-hover:border-white transition-colors"
          ></span>
          <span class="text-lg font-medium text-white">Programming</span>
        </a>
      </div>
    </div>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
