---
import PhotographyLayout from "../../layouts/PhotographyLayout.astro";
import { getCollection } from "astro:content";

const photos = await getCollection("photography");
const sorted = photos.sort((a, b) => a.data.order - b.data.order);
---

<PhotographyLayout>
  <div
    id="photo-viewer"
    class="w-full h-full relative flex items-center justify-center"
  >
    {
      sorted.map((photo, i) => (
        <figure
          class:list={[
            "photo-slide absolute inset-0 flex items-center justify-center transition-opacity duration-500",
            i === 0 ? "opacity-100" : "opacity-0 pointer-events-none",
          ]}
          data-index={i}
        >
          <img
            src={photo.data.src}
            alt={photo.data.alt}
            class="max-w-full max-h-full object-contain"
          />
          {/* {photo.data.caption && (
          <figcaption class="absolute bottom-6 left-1/2 -translate-x-1/2 text-center opacity-0 transition-opacity duration-300" id={`caption-${i}`}>
            <p class="text-sm" style="color: var(--color-text);">{photo.data.caption}</p>
            {photo.data.camera && (
              <p class="text-xs mt-1" style="color: var(--color-accent);">
                {photo.data.camera}{photo.data.lens ? ` · ${photo.data.lens}` : ''}
              </p>
            )}
          </figcaption>
        )} */}
        </figure>
      ))
    }

    <button
      id="nav-prev"
      class="absolute left-0 top-0 w-1/3 h-full z-10 cursor-w-resize opacity-0 hover:opacity-100 transition-opacity duration-200 flex items-center justify-start pl-6"
      aria-label="Previous photo"
    >
      <span class="text-3xl select-none" style="color: var(--color-accent);"
        >&#8249;</span
      >
    </button>

    <button
      id="nav-next"
      class="absolute right-0 top-0 w-1/3 h-full z-10 cursor-e-resize opacity-0 hover:opacity-100 transition-opacity duration-200 flex items-center justify-end pr-6"
      aria-label="Next photo"
    >
      <span class="text-3xl select-none" style="color: var(--color-accent);"
        >&#8250;</span
      >
    </button>
  </div>
</PhotographyLayout>

<script define:vars={{ total: sorted.length }}>
  function setupPhotoViewer() {
    let current = 0;

    function show(index) {
      const slides = document.querySelectorAll(".photo-slide");
      slides.forEach((slide, i) => {
        if (i === index) {
          slide.classList.remove("opacity-0", "pointer-events-none");
          slide.classList.add("opacity-100");
        } else {
          slide.classList.add("opacity-0", "pointer-events-none");
          slide.classList.remove("opacity-100");
        }
      });
      current = index;
    }

    const prev = document.getElementById("nav-prev");
    const next = document.getElementById("nav-next");
    if (!prev || !next) return;

    prev.addEventListener("click", () => {
      show((current - 1 + total) % total);
    });

    next.addEventListener("click", () => {
      show((current + 1) % total);
    });

    function handleKeyDown(e) {
      if (e.key === "ArrowLeft") show((current - 1 + total) % total);
      if (e.key === "ArrowRight") show((current + 1) % total);
    }

    document.removeEventListener("keydown", handleKeyDown);
    document.addEventListener("keydown", handleKeyDown);
  }

  document.addEventListener("astro:page-load", setupPhotoViewer);
</script>
