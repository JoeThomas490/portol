---
import PhotographyLayout from "../../layouts/PhotographyLayout.astro";
import { getPhotoCollections } from "../../lib/photography";
import ChevronLeft from "@lucide/astro/icons/chevron-left";

const collectionsData = await getPhotoCollections();
const collectionNames = collectionsData.map((col) => col.name);
---

<PhotographyLayout>
  <!-- Sidebar -->
  <aside
    id="collections-sidebar"
    class="collections-sidebar z-20 md:z-5 flex flex-col overflow-hidden transition-all duration-300 ease-in-out collapsed"
    style="background-color: var(--color-bg);"
  >
    <!-- Title bar — always visible, acts as toggle -->
    <button
      id="sidebar-toggle"
      class="flex items-center gap-2 px-5 py-4 w-full bg-transparent border-none cursor-pointer"
      style="color: var(--color-accent);"
    >
      <h2
        id="active-collection-name"
        class="text-[0.65rem] font-bold tracking-widest uppercase m-0"
      >
        {collectionNames[0] ?? "Collections"}
      </h2>
      <span
        id="sidebar-chevron"
        class="flex items-center transition-transform duration-300"
      >
        <ChevronLeft size={12} />
      </span>
    </button>

    <div class="flex flex-col justify-start flex-1 min-h-0">
      <!-- Collection list -->
      <nav
        id="collections-nav"
        class="flex flex-col overflow-hidden transition-all duration-300 ease-in-out opacity-100 max-h-[500px]"
      >
        {
          collectionsData.map((col, ci) => (
            <div class="last:border-b-0" data-collection-index={ci}>
              <button
                class:list={[
                  "collection-header flex items-center justify-between w-full px-6 py-2.5 bg-transparent border-none cursor-pointer text-[0.8125rem] font-medium transition-colors duration-150",
                  ci === 0 && "is-active",
                ]}
                style="color: var(--color-text);"
                data-collection={ci}
              >
                <span>{col.name}</span>
              </button>
            </div>
          ))
        }
      </nav>

      <a
        href="/photography/about"
        class="sidebar-about-link mt-auto block px-5 py-4 text-[0.65rem] font-bold tracking-widest no-underline uppercase transition-colors duration-150"
        style="color: var(--color-accent);"
      >
        About
      </a>
    </div>
  </aside>

  <div
    id="sidebar-backdrop"
    class="sidebar-backdrop absolute -inset-10 -mt-10 z-10 bg-black/20 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"
    aria-hidden="true"
  >
  </div>

  <!-- Photo viewer -->
  <div
    id="photo-viewer"
    class="w-full min-w-0 flex-1 h-full relative flex items-center justify-center overflow-hidden"
  >
    {
      collectionsData.length === 0 ? (
        <p class="text-sm" style="color: var(--color-accent);">
          No collections found. Add a collection markdown file and upload images
          to the matching R2 prefix.
        </p>
      ) : (
        collectionsData.map((col, ci) =>
          col.photos.map((photo, pi) => (
            <figure
              class:list={[
                "photo-slide absolute inset-0 flex items-center justify-center p-3 sm:p-4 md:p-0 transition-opacity duration-500",
                ci === 0 && pi === 0
                  ? "opacity-100"
                  : "opacity-0 pointer-events-none",
              ]}
              data-collection={ci}
              data-photo={pi}
            >
              <img
                src={photo.src}
                alt={photo.alt}
                class="max-w-full max-h-[calc(100vh-11rem)] md:max-h-full object-contain"
              />
            </figure>
          )),
        )
      )
    }

    {
      collectionsData.length > 0 && (
        <>
          <button
            id="nav-prev"
            class="absolute left-0 top-0 w-1/3 h-full z-10 cursor-w-resize opacity-0 hover:opacity-100 transition-opacity duration-200 flex items-center justify-start pl-6"
            aria-label="Previous photo"
          >
            <span
              class="text-3xl select-none"
              style="color: var(--color-accent);"
            >
              &#8249;
            </span>
          </button>

          <button
            id="nav-next"
            class="absolute right-0 top-0 w-1/3 h-full z-10 cursor-e-resize opacity-0 hover:opacity-100 transition-opacity duration-200 flex items-center justify-end pr-6"
            aria-label="Next photo"
          >
            <span
              class="text-3xl select-none"
              style="color: var(--color-accent);"
            >
              &#8250;
            </span>
          </button>
        </>
      )
    }
  </div>
</PhotographyLayout>

<style>
  .collection-header:hover {
    background-color: var(--color-muted);
  }

  .collection-header.is-active span {
    font-weight: 600;
  }

  .sidebar-about-link:hover {
    color: var(--color-text);
  }

  #collections-sidebar {
    position: absolute;
    top: 3rem;
    left: 0;
    bottom: 0;
    width: min(240px, 85vw);
  }

  #collections-sidebar.collapsed {
    width: auto;
    min-width: auto;
  }

  #collections-sidebar.collapsed #collections-nav {
    max-height: 0;
    opacity: 0;
  }

  #collections-sidebar.collapsed #sidebar-chevron {
    transform: rotate(180deg);
  }

  @media (max-width: 767px) {
    #collections-sidebar.collapsed {
      bottom: auto;
      height: auto;
      border-bottom-right-radius: 0.75rem;
      box-shadow: 0 4px 24px rgb(0 0 0 / 12%);
    }

    #collections-sidebar:not(.collapsed) {
      box-shadow: 4px 0 24px rgb(0 0 0 / 12%);
    }

    #collections-sidebar:not(.collapsed) + .sidebar-backdrop {
      opacity: 1;
      pointer-events: auto;
    }
  }

  @media (min-width: 768px) {
    #collections-sidebar {
      position: relative;
      top: auto;
      left: auto;
      bottom: auto;
      margin-top: 3rem;
      height: calc(100% - 3rem);
      width: 220px;
      min-width: 220px;
      flex-shrink: 0;
      box-shadow: none;
      border-radius: 0;
    }

    #collections-sidebar.collapsed {
      width: auto;
      min-width: auto;
      height: calc(100% - 3rem);
    }
  }
</style>

<script define:vars={{ collectionsData }}>
  function setupPhotoViewer() {
    let currentCollection = 0;
    let currentPhoto = 0;

    const sidebar = document.getElementById("collections-sidebar");
    const toggle = document.getElementById("sidebar-toggle");
    const backdrop = document.getElementById("sidebar-backdrop");
    const slides = document.querySelectorAll(".photo-slide");
    const headers = document.querySelectorAll(".collection-header");
    const activeLabel = document.getElementById("active-collection-name");

    if (toggle && sidebar) {
      toggle.addEventListener("click", () => {
        sidebar.classList.toggle("collapsed");
      });
    }

    if (backdrop && sidebar) {
      backdrop.addEventListener("click", () => {
        sidebar.classList.add("collapsed");
      });
    }

    function showPhoto(ci, pi) {
      slides.forEach((slide) => {
        const sc = Number(slide.getAttribute("data-collection"));
        const sp = Number(slide.getAttribute("data-photo"));
        if (sc === ci && sp === pi) {
          slide.classList.remove("opacity-0", "pointer-events-none");
          slide.classList.add("opacity-100");
        } else {
          slide.classList.add("opacity-0", "pointer-events-none");
          slide.classList.remove("opacity-100");
        }
      });

      headers.forEach((h) => {
        const hc = Number(h.getAttribute("data-collection"));
        h.classList.toggle("is-active", hc === ci);
      });

      if (activeLabel) {
        activeLabel.textContent = collectionsData[ci].name;
      }

      currentCollection = ci;
      currentPhoto = pi;
    }

    headers.forEach((header) => {
      header.addEventListener("click", () => {
        const ci = Number(header.getAttribute("data-collection"));
        if (ci !== currentCollection) {
          showPhoto(ci, 0);
        }
      });
    });

    const prev = document.getElementById("nav-prev");
    const next = document.getElementById("nav-next");

    if (prev) {
      prev.addEventListener("click", () => {
        const total = collectionsData[currentCollection].photos.length;
        showPhoto(currentCollection, (currentPhoto - 1 + total) % total);
      });
    }

    if (next) {
      next.addEventListener("click", () => {
        const total = collectionsData[currentCollection].photos.length;
        showPhoto(currentCollection, (currentPhoto + 1) % total);
      });
    }

    function handleKeyDown(e) {
      const total = collectionsData[currentCollection].photos.length;
      if (e.key === "ArrowLeft")
        showPhoto(currentCollection, (currentPhoto - 1 + total) % total);
      if (e.key === "ArrowRight")
        showPhoto(currentCollection, (currentPhoto + 1) % total);
    }

    document.removeEventListener("keydown", handleKeyDown);
    document.addEventListener("keydown", handleKeyDown);
  }

  document.addEventListener("astro:page-load", setupPhotoViewer);
</script>
