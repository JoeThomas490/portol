---
import PhotographyLayout from "../../layouts/PhotographyLayout.astro";
import { getPhotoCollections } from "../../lib/photography";
import {
  GRID_COLUMNS,
  GRID_PLACEMENTS,
  getGridCollections,
} from "../../lib/photographyGrid";

const CYCLE_INTERVAL_MS = 4500;
const CYCLE_STAGGER_MS = 600;
const CYCLE_VARIANCE_MS = 750;
const FADE_DURATION_MS = 400;

const realCollections = await getPhotoCollections();
const collections = getGridCollections(realCollections);

const cells = GRID_PLACEMENTS.map((placement, i) => {
  const collection = collections[placement.collectionIndex];
  return {
    id: `cell-${i}`,
    placement,
    name: collection?.name ?? "",
    date: collection?.date ? collection.date.toISOString().slice(0, 10) : "",
    photos: collection?.photos.map((p) => p.src) ?? [],
    alt: collection?.photos[0]?.alt ?? collection?.name ?? "",
  };
});
---

<PhotographyLayout>
  <div class="grid-scroll flex-1 min-w-0 h-full overflow-auto">
    <div
      class="photo-grid"
      style={`--grid-cols: ${GRID_COLUMNS}; --cell-fade-ms: ${FADE_DURATION_MS}ms;`}
    >
      {
        cells.map((cell) => (
          <a
            id={cell.id}
            href="/photography/slideshow"
            class="grid-cell"
            style={`grid-column: ${cell.placement.col}; grid-row: ${cell.placement.row};`}
            data-cell-id={cell.id}
            data-name={cell.name}
            data-date={cell.date}
            data-photos={JSON.stringify(cell.photos)}
            aria-label={cell.name}
          >
            {cell.photos.length > 0 ? (
              <img
                src={cell.photos[0]}
                alt={cell.alt}
                loading="lazy"
                decoding="async"
                class="cell-img"
              />
            ) : (
              <div class="cell-placeholder" aria-hidden="true" />
            )}
          </a>
        ))
      }
    </div>
  </div>

  <div id="hover-panel" class="hover-panel" aria-hidden="true">
    <span id="hover-name" class="hover-name"></span>
    <span id="hover-date" class="hover-date"></span>
  </div>
</PhotographyLayout>

<style>
  .grid-scroll {
    padding: 0.75rem;
    box-sizing: border-box;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(var(--grid-cols, 6), 1fr);
    grid-auto-rows: min(calc(100vw / var(--grid-cols, 6)), 250px);
    gap: 4px;
    width: 100%;
  }

  .grid-cell {
    position: relative;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: transparent;
    cursor: pointer;
    text-decoration: none;
    outline: none;
    transition:
      opacity 0.25s ease,
      filter 0.25s ease;
  }

  .grid-cell:hover {
    background-color: color-mix(in srgb, var(--color-accent) 50%, transparent);
  }

  .grid-cell:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .photo-grid:has(.grid-cell:hover) .grid-cell:not(:hover),
  .photo-grid:has(.grid-cell:focus-visible) .grid-cell:not(:focus-visible) {
    opacity: 0.1;
    filter: grayscale(1);
  }

  .cell-img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    margin-top: auto;
    margin-right: auto;
    transition: opacity var(--cell-fade-ms, 400ms) ease;
  }

  .cell-img.is-fading {
    opacity: 0;
  }

  .cell-placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--color-muted);
  }

  .hover-panel {
    position: fixed;
    bottom: 1rem;
    left: 1rem;
    z-index: 40;
    display: inline-flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 1.2rem 1.2rem;
    background-color: var(--color-accent);
    color: var(--color-invert);
    opacity: 0;
    transform: translateY(6px);
    pointer-events: none;
    transition:
      opacity 0.15s ease,
      transform 0.15s ease;
    max-width: min(80vw, 420px);
  }

  .hover-panel.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .hover-name {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    line-height: 1.1;
  }

  .hover-date {
    font-size: 1.2rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.85;
    line-height: 1.1;
  }
</style>

<script
  define:vars={{
    CYCLE_INTERVAL_MS,
    CYCLE_STAGGER_MS,
    CYCLE_VARIANCE_MS,
    FADE_DURATION_MS,
  }}
>
  function setupPhotoGrid() {
    const grid = document.querySelector(".photo-grid");
    const cells = Array.from(document.querySelectorAll(".grid-cell"));
    const panel = document.getElementById("hover-panel");
    const nameEl = document.getElementById("hover-name");
    const dateEl = document.getElementById("hover-date");

    const timers = [];
    const timeouts = [];
    let paused = false;

    if (grid) {
      grid.addEventListener("mouseenter", () => {
        paused = true;
      });
      grid.addEventListener("mouseleave", () => {
        paused = false;
      });
    }

    function clearAll() {
      timers.forEach((t) => clearInterval(t));
      timeouts.forEach((t) => clearTimeout(t));
      timers.length = 0;
      timeouts.length = 0;
    }

    function formatDate(iso) {
      if (!iso) return "";
      const d = new Date(iso);
      if (Number.isNaN(d.getTime())) return "";
      return d.toLocaleDateString("en-GB", {
        month: "short",
        year: "numeric",
      });
    }

    cells.forEach((cell, i) => {
      const raw = cell.getAttribute("data-photos") ?? "[]";
      let photos = [];
      try {
        photos = JSON.parse(raw);
      } catch {
        photos = [];
      }

      const img = cell.querySelector(".cell-img");
      if (img && photos.length > 1) {
        let index = 0;
        const startDelay =
          CYCLE_STAGGER_MS * Math.random() +
          i * CYCLE_VARIANCE_MS * Math.random();
        const swapDelay = Math.round(FADE_DURATION_MS / 2);

        timeouts.push(
          setTimeout(() => {
            const timer = setInterval(() => {
              if (paused) return;
              index = (index + 1) % photos.length;
              const next = photos[index];
              img.classList.add("is-fading");
              setTimeout(() => {
                img.src = next;
                img.classList.remove("is-fading");
              }, swapDelay);
            }, CYCLE_INTERVAL_MS);
            timers.push(timer);
          }, startDelay),
        );
      }

      cell.addEventListener("mouseenter", () => {
        if (!panel || !nameEl || !dateEl) return;
        const name = cell.getAttribute("data-name") ?? "";
        const date = cell.getAttribute("data-date") ?? "";
        nameEl.textContent = name;
        dateEl.textContent = formatDate(date);
        panel.classList.add("is-visible");
      });

      cell.addEventListener("mouseleave", () => {
        if (!panel) return;
        panel.classList.remove("is-visible");
      });

      cell.addEventListener("focus", () => {
        if (!panel || !nameEl || !dateEl) return;
        const name = cell.getAttribute("data-name") ?? "";
        const date = cell.getAttribute("data-date") ?? "";
        nameEl.textContent = name;
        dateEl.textContent = formatDate(date);
        panel.classList.add("is-visible");
      });

      cell.addEventListener("blur", () => {
        if (!panel) return;
        panel.classList.remove("is-visible");
      });
    });

    document.addEventListener("astro:before-swap", clearAll, { once: true });
  }

  document.addEventListener("astro:page-load", setupPhotoGrid);
</script>
