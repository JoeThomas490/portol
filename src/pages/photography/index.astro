---
import PhotographyLayout from "../../layouts/PhotographyLayout.astro";
import { getPhotoCollections } from "../../lib/photography";
import {
  GRID_COLUMNS,
  GRID_PLACEMENTS,
  getGridCollections,
} from "../../lib/photographyGrid";

const CYCLE_INTERVAL_MS = 4500;
const CYCLE_STAGGER_MS = 600;
const CYCLE_VARIANCE_MS = 750;
const FADE_DURATION_MS = 100;

const realCollections = await getPhotoCollections();
const collections = getGridCollections(realCollections);

const cells = GRID_PLACEMENTS.map((placement, i) => {
  const collection = collections[placement.collectionIndex];
  return {
    id: `cell-${i}`,
    placement,
    slug: collection?.slug,
    name: collection?.name ?? "",
    date: collection?.date ? collection.date.toISOString().slice(0, 10) : "",
    photos: collection?.photos.map((p) => p.src) ?? [],
    alt: collection?.photos[0]?.alt ?? collection?.name ?? "",
  };
});
---

<PhotographyLayout>
  <div class="grid-scroll flex-1 min-w-0 h-full overflow-auto">
    <div
      class="photo-grid"
      style={`--grid-cols: ${GRID_COLUMNS}; --cell-fade-ms: ${FADE_DURATION_MS}ms;`}
    >
      {
        cells.map((cell) =>
          cell.slug ? (
            <a
              id={cell.id}
              href={`/photography/${cell.slug}`}
              class="grid-cell"
              style={`grid-column: ${cell.placement.col}; grid-row: ${cell.placement.row};`}
              data-cell-id={cell.id}
              data-name={cell.name}
              data-date={cell.date}
              data-photos={JSON.stringify(cell.photos)}
              aria-label={cell.name}
            >
              {cell.photos.length > 0 ? (
                <img
                  src={cell.photos[0]}
                  alt={cell.alt}
                  loading="lazy"
                  decoding="async"
                  class="cell-img"
                />
              ) : (
                <div class="cell-placeholder" aria-hidden="true" />
              )}
            </a>
          ) : (
            <div
              id={cell.id}
              class="grid-cell"
              style={`grid-column: ${cell.placement.col}; grid-row: ${cell.placement.row};`}
              data-cell-id={cell.id}
              data-name={cell.name}
              data-date={cell.date}
              data-photos={JSON.stringify(cell.photos)}
              aria-label={cell.name}
            >
              {cell.photos.length > 0 ? (
                <img
                  src={cell.photos[0]}
                  alt={cell.alt}
                  loading="lazy"
                  decoding="async"
                  class="cell-img"
                />
              ) : (
                <div class="cell-placeholder" aria-hidden="true" />
              )}
            </div>
          ),
        )
      }
    </div>
  </div>

  <div id="hover-panel" class="hover-panel" aria-hidden="true">
    <span id="hover-name" class="hover-name"></span>
    <span id="hover-date" class="hover-date"></span>
  </div>
</PhotographyLayout>

<style>
  .grid-scroll {
    padding: 0.75rem;
    box-sizing: border-box;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(var(--grid-cols, 6), 1fr);
    grid-auto-rows: min(calc(100vw / var(--grid-cols, 6)), 250px);
    gap: 4px;
    width: 100%;
    padding: 40px;
  }

  .grid-cell {
    position: relative;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: transparent;
    cursor: pointer;
    text-decoration: none;
    outline: none;
    transition:
      opacity 0.25s ease,
      filter 0.25s ease;
  }

  .grid-cell:hover {
    background-color: color-mix(in srgb, var(--color-accent) 80%, transparent);
  }

  .grid-cell:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .photo-grid:has(.grid-cell:hover) .grid-cell:not(:hover),
  .photo-grid:has(.grid-cell:focus-visible) .grid-cell:not(:focus-visible) {
    opacity: 0.1;
    filter: grayscale(1);
  }

  .cell-img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    margin-top: auto;
    margin-right: auto;
    transition: opacity var(--cell-fade-ms, 400ms) ease;
  }

  .cell-img.is-fading {
    opacity: 100;
  }

  .cell-placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--color-muted);
  }

  .hover-panel {
    position: fixed;
    bottom: 1rem;
    left: 1rem;
    z-index: 40;
    display: inline-flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 1.2rem 1.2rem;
    background-color: var(--color-accent);
    color: var(--color-invert);
    opacity: 0;
    transform: translateY(6px);
    pointer-events: none;
    transition:
      opacity 0.15s ease,
      transform 0.15s ease;
    max-width: min(80vw, 420px);
  }

  .hover-panel.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .hover-name {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    line-height: 1.1;
  }

  .hover-date {
    font-size: 1.2rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.85;
    line-height: 1.1;
  }
</style>

<script
  define:vars={{
    CYCLE_INTERVAL_MS,
    CYCLE_STAGGER_MS,
    CYCLE_VARIANCE_MS,
    FADE_DURATION_MS,
  }}
>
  function setupPhotoGrid() {
    const grid = document.querySelector(".photo-grid");
    const cells = Array.from(document.querySelectorAll(".grid-cell"));
    const panel = document.getElementById("hover-panel");
    const nameEl = document.getElementById("hover-name");
    const dateEl = document.getElementById("hover-date");

    const swapDelay = FADE_DURATION_MS / 2;

    const cellState = cells
      .map((cell, i) => {
        const raw = cell.getAttribute("data-photos") ?? "[]";
        let photos = [];
        try {
          photos = JSON.parse(raw);
        } catch {
          photos = [];
        }

        const img = cell.querySelector(".cell-img");
        if (!img || photos.length <= 1) return null;

        const startDelay =
          CYCLE_STAGGER_MS * Math.random() +
          i * CYCLE_VARIANCE_MS * Math.random();

        return {
          img,
          photos,
          index: 0,
          timeUntilFade: CYCLE_INTERVAL_MS + startDelay,
          fadeRemaining: 0,
          pendingSrc: null,
        };
      })
      .filter((s) => s !== null);

    let rafId = 0;
    let lastTick = 0;
    let stopped = false;

    function tick(now) {
      if (stopped) return;
      if (lastTick === 0) lastTick = now;

      const rawDt = now - lastTick;
      const isPaused = grid
        ? grid.querySelector(".grid-cell:hover") !== null
        : false;
      // Cap dt so a background tab / long frame can't fast-forward everything.
      const dt = Math.min(rawDt, 100);
      lastTick = now;

      for (const s of cellState) {
        if (s.fadeRemaining > 0) {
          s.fadeRemaining -= dt;
          if (s.fadeRemaining <= 0) {
            if (s.pendingSrc !== null) {
              s.img.src = s.pendingSrc;
              s.pendingSrc = null;
            }
            s.img.classList.remove("is-fading");
            s.fadeRemaining = 0;
            s.timeUntilFade = CYCLE_INTERVAL_MS;
          }
          continue;
        }

        s.timeUntilFade -= isPaused ? 0 : dt;
        if (s.timeUntilFade <= 0) {
          s.index = (s.index + 1) % s.photos.length;
          s.pendingSrc = s.photos[s.index];
          s.img.classList.add("is-fading");
          s.fadeRemaining = swapDelay;
        }
      }

      rafId = requestAnimationFrame(tick);
    }

    function formatDate(iso) {
      if (!iso) return "";
      const d = new Date(iso);
      if (Number.isNaN(d.getTime())) return "";
      return d.toLocaleDateString("en-GB", {
        month: "short",
        year: "numeric",
      });
    }

    cells.forEach((cell) => {
      cell.addEventListener("mouseenter", () => {
        if (!panel || !nameEl || !dateEl) return;
        const name = cell.getAttribute("data-name") ?? "";
        const date = cell.getAttribute("data-date") ?? "";
        nameEl.textContent = name;
        dateEl.textContent = formatDate(date);
        panel.classList.add("is-visible");
      });

      cell.addEventListener("mouseleave", () => {
        if (!panel) return;
        panel.classList.remove("is-visible");
      });

      cell.addEventListener("focus", () => {
        if (!panel || !nameEl || !dateEl) return;
        const name = cell.getAttribute("data-name") ?? "";
        const date = cell.getAttribute("data-date") ?? "";
        nameEl.textContent = name;
        dateEl.textContent = formatDate(date);
        panel.classList.add("is-visible");
      });

      cell.addEventListener("blur", () => {
        if (!panel) return;
        panel.classList.remove("is-visible");
      });
    });

    function stop() {
      stopped = true;
      if (rafId !== 0) cancelAnimationFrame(rafId);
    }

    document.addEventListener("astro:before-swap", stop, { once: true });

    if (cellState.length > 0) {
      rafId = requestAnimationFrame(tick);
    }
  }

  document.addEventListener("astro:page-load", setupPhotoGrid);
</script>
