---
import PhotographyLayout from "../../layouts/PhotographyLayout.astro";
import { getPhotoCollections } from "../../lib/photography";

export async function getStaticPaths() {
  const collections = await getPhotoCollections();
  return collections
    .filter((c) => c.slug)
    .map((collection) => ({
      params: { slug: collection.slug },
      props: { collection },
    }));
}

const { collection } = Astro.props;
const photos = collection.photos;
---

<PhotographyLayout title={collection.name}>
  <div
    id="sidebar-backdrop"
    class="sidebar-backdrop absolute -inset-10 -mt-10 z-10 bg-black/20 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"
    aria-hidden="true"
  >
  </div>

  <!-- Photo viewer -->
  <div
    id="photo-viewer"
    class="w-full min-w-0 flex-1 h-full relative flex items-center justify-center overflow-hidden"
  >
    {
      photos.length === 0 ? (
        <p class="text-sm" style="color: var(--color-accent);">
          No photos found in this collection.
        </p>
      ) : (
        photos.map((photo, pi) => (
          <figure
            class:list={[
              "photo-slide absolute inset-0 flex items-center justify-center p-3 sm:p-4 md:p-0 transition-opacity duration-500",
              pi === 0 ? "opacity-100" : "opacity-0 pointer-events-none",
            ]}
            data-photo={pi}
          >
            <img
              src={photo.src}
              alt={photo.alt}
              class="max-w-full max-h-[calc(100vh-11rem)] md:max-h-full object-contain"
            />
          </figure>
        ))
      )
    }

    {
      photos.length > 0 && (
        <>
          <button
            id="nav-prev"
            class="absolute left-0 top-0 w-1/3 h-full z-10 cursor-w-resize opacity-0 hover:opacity-100 transition-opacity duration-200 flex items-center justify-start pl-6"
            aria-label="Previous photo"
          >
            <span
              class="text-3xl select-none"
              style="color: var(--color-accent);"
            >
              &#8249;
            </span>
          </button>

          <button
            id="nav-next"
            class="absolute right-0 top-0 w-1/3 h-full z-10 cursor-e-resize opacity-0 hover:opacity-100 transition-opacity duration-200 flex items-center justify-end pr-6"
            aria-label="Next photo"
          >
            <span
              class="text-3xl select-none"
              style="color: var(--color-accent);"
            >
              &#8250;
            </span>
          </button>
        </>
      )
    }
  </div>
</PhotographyLayout>

<script define:vars={{ totalPhotos: photos.length }}>
  function setupCollectionViewer() {
    if (totalPhotos === 0) return;

    let currentPhoto = 0;
    const slides = document.querySelectorAll(".photo-slide");

    function showPhoto(pi) {
      slides.forEach((slide) => {
        const sp = Number(slide.getAttribute("data-photo"));
        if (sp === pi) {
          slide.classList.remove("opacity-0", "pointer-events-none");
          slide.classList.add("opacity-100");
        } else {
          slide.classList.add("opacity-0", "pointer-events-none");
          slide.classList.remove("opacity-100");
        }
      });
      currentPhoto = pi;
    }

    const prev = document.getElementById("nav-prev");
    const next = document.getElementById("nav-next");

    if (prev) {
      prev.addEventListener("click", () => {
        showPhoto((currentPhoto - 1 + totalPhotos) % totalPhotos);
      });
    }

    if (next) {
      next.addEventListener("click", () => {
        showPhoto((currentPhoto + 1) % totalPhotos);
      });
    }

    function handleKeyDown(e) {
      if (e.key === "ArrowLeft")
        showPhoto((currentPhoto - 1 + totalPhotos) % totalPhotos);
      if (e.key === "ArrowRight") showPhoto((currentPhoto + 1) % totalPhotos);
    }

    document.removeEventListener("keydown", handleKeyDown);
    document.addEventListener("keydown", handleKeyDown);
  }

  document.addEventListener("astro:page-load", setupCollectionViewer);
</script>
