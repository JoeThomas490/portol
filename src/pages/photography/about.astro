---
import PhotographyLayout from "../../layouts/PhotographyLayout.astro";
import ArrowLeft from "@lucide/astro/icons/arrow-left";
---

<PhotographyLayout title="About — Photography">
  <div class="w-full h-full flex flex-col md:flex-row items-center">
    <!-- Profile photo -->
    <div class="w-full md:flex-1 h-64 md:h-[80vh] overflow-hidden ml-12">
      <img
        src="https://assets.joenoseph.co.uk/me/me_001.jpg"
        alt="Profile photo"
        class="w-full h-full object-cover"
      />
    </div>

    <!-- Text content -->
    <div
      class="w-full md:flex-2 h-full flex flex-col justify-start px-12 py-16 md:px-16 md:py-24 overflow-y-auto"
    >
      <a
        href="/photography"
        class="inline-flex items-center gap-2 text-xs font-medium uppercase tracking-widest no-underline mb-10 transition-colors duration-150 hover:opacity-70"
        style="color: var(--color-accent);"
      >
        <ArrowLeft size={14} />
        Back to Gallery
      </a>

      <h1
        class="text-3xl md:text-4xl font-bold tracking-tight mb-6"
        style="color: var(--color-text);"
      >
        About
      </h1>

      <div
        class="space-y-4 text-base leading-relaxed"
        style="color: var(--color-accent);"
      >
        <p></p>
        <p></p>
      </div>
    </div>
  </div>
</PhotographyLayout>
