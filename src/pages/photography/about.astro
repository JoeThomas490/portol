---
import PhotographyLayout from "../../layouts/PhotographyLayout.astro";
import ArrowLeft from "@lucide/astro/icons/arrow-left";
---

<PhotographyLayout title="About — Photography">
  <div class="w-full h-full flex flex-col md:flex-row items-center">
    <!-- Profile photo -->
    <div class="w-full md:flex-1 h-64 md:h-[80vh] overflow-hidden ml-12">
      <img
        src="https://assets.joenoseph.co.uk/me/me_001.jpg"
        alt="Profile photo"
        class="w-full h-full object-cover"
      />
    </div>

    <!-- Text content -->
    <div
      class="w-full md:flex-2 h-full flex flex-col justify-start px-12 py-16 md:px-16 md:py-24 overflow-y-auto"
    >
      <a
        href="/photography"
        class="inline-flex items-center gap-2 text-xs font-medium uppercase tracking-widest no-underline mb-10 transition-colors duration-150 hover:opacity-70"
        style="color: var(--color-accent);"
      >
        <ArrowLeft size={14} />
        Back to Gallery
      </a>

      <h1
        class="text-3xl md:text-4xl font-bold tracking-tight mb-6"
        style="color: var(--color-text);"
      >
        About
      </h1>

      <div
        class="space-y-4 text-base leading-relaxed"
        style="color: var(--color-accent);"
      >
        <p>
          Joe Martin Thomas (b. 1996) is a UK-based photographer, currently
          living in Liverpool. A self-taught photographer, Joe specializes in
          portraiture, events, and lifestyle photography, shooting both on film
          and digital. Joe is still developing his visual style and language,
          however, he is magnetised to capturing dynamic energy and movement in
          busy environments, juxtaposed with relaxing and tranquil landscape
          compositions and portraits.
        </p>
        <h2
          class="text-2xl font-bold tracking-tight mb-6"
          style="color: var(--color-text);"
        >
          Selected Works
        </h2>
        <h2
          class="text-2xl font-bold tracking-tight mb-6"
          style="color: var(--color-text);"
        >
          2023
        </h2>
        <p>
          Portrait of Britain Vol. 6 Winner - <a
            href="https://pobwinners.1854.photography/"
            target="_blank"
            class="text-blue-500">1854 Photography</a
          >
        </p>
        <p>9Lives Exhibition - Liverpool - 9th February</p>
        <h2
          class="text-2xl font-bold tracking-tight mb-6"
          style="color: var(--color-text);"
        >
          2021
        </h2>
        <p>
          Winning entry for Tate Collective’s Open Call - Photographing the
          North West, inspired by Don McCullin. Shown in Tate Liverpool, May
          18th - June 6th
        </p>
        <p>WellSpoken Zine Issues 1-4</p>
      </div>
    </div>
  </div>
</PhotographyLayout>
