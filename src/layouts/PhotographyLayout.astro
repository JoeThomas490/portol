---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title?: string;
}

const { title = "Photography" } = Astro.props;
---

<BaseLayout title={title} mode="photography">
  <div
    class="w-full h-[calc(100vh-5rem)] mt-12 relative overflow-hidden flex min-w-0"
  >
    <slot />
  </div>
</BaseLayout>
