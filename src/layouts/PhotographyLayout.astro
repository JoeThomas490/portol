---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title?: string;
}

const { title = "Photography" } = Astro.props;
---

<BaseLayout title={title} mode="photography">
  <div class="w-full h-[calc(100vh-4rem)] mt-6 relative overflow-hidden flex">
    <slot />
  </div>
</BaseLayout>
