---
import { ViewTransitions } from "astro:transitions";
import Favicons from "../components/Favicons.astro";
import ModeBubble from "../components/ModeBubble.astro";

interface Props {
  title: string;
  mode: "photography" | "programming";
}

const { title, mode } = Astro.props;
---

<!doctype html>
<html lang="en" data-mode={mode}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Joe Thomas" />
    <Favicons variant={mode === "photography" ? "photo" : "dev"} />
    <title>Joe Thomas | {title}</title>
    <ViewTransitions />
  </head>
  <body
    class="min-h-dvh"
    style={`background-color: var(--color-bg); color: var(--color-text);`}
  >
    <nav transition:persist class="fixed top-0 left-0 right-0 z-50 p-6">
      <div class="flex items-center justify-between">
        <div class="flex flex-col items-start gap-0">
          <a
            href="/"
            class="text-lg font-bold tracking-tight"
            style="color: var(--color-text);"
          >
            Joe Thomas
          </a>
          <span
            class="text-lg font-bold tracking-tight text-orange-400"
            id="mode-label"></span>
        </div>
      </div>
    </nav>

    <ModeBubble />

    <main class="pt-4">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
  @import "../styles/modes/photography.css";
  @import "../styles/modes/programming.css";
  @import "../styles/transitions.css";
</style>
