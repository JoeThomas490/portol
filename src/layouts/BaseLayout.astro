---
import { ViewTransitions } from "astro:transitions";
import { Camera, CodeXml } from "@lucide/astro";

interface Props {
  title: string;
  mode: "photography" | "programming";
}

const { title, mode } = Astro.props;
---

<!doctype html>
<html lang="en" data-mode={mode}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Joe Thomas" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Joe Thomas</title>
    <ViewTransitions />
  </head>
  <body
    class="min-h-dvh"
    style={`background-color: var(--color-bg); color: var(--color-text);`}
  >
    <nav transition:persist class="fixed top-0 left-0 right-0 z-50 p-6">
      <div class="flex items-center justify-between">
        <div class="flex flex-col items-start gap-0">
          <a
            href="/"
            class="text-lg font-bold tracking-tight"
            style="color: var(--color-text);"
          >
            Joe Thomas
          </a>
          <span
            class="text-lg font-bold tracking-tight text-orange-400"
            id="mode-label"></span>
        </div>
      </div>
    </nav>

    <div
      id="mode-bubble"
      transition:persist
      class="group fixed bottom-6 right-6 z-50 flex flex-col items-center"
    >
      <div
        class="flex flex-col gap-0.5 p-1.5 mb-2 rounded-2xl shadow-[0_4px_20px_rgba(0,0,0,0.15)] origin-bottom invisible scale-y-0 translate-y-2.5 opacity-0 pointer-events-none transition-[opacity,transform,visibility] duration-400 ease-mode group-hover:visible group-hover:scale-y-100 group-hover:translate-y-0 group-hover:opacity-100 group-hover:pointer-events-auto group-hover:delay-0 [transition-delay:0s,0s,0.4s] group-hover:[transition-delay:0s,0s,0s]"
        style="background-color: var(--color-muted); border: 1px solid var(--color-border);"
      >
        <a
          href="/photography"
          data-astro-prefetch="load"
          class="mode-option flex items-center gap-2.5 py-2.5 px-4 rounded-xl whitespace-nowrap no-underline transition-[background-color,opacity] duration-150 ease-linear hover:bg-[var(--color-border)]"
          data-mode="photography"
        >
          <Camera size={18} />
          <span class="text-sm font-medium">Photography</span>
        </a>
        <a
          href="/programming"
          data-astro-prefetch="load"
          class="mode-option flex items-center gap-2.5 py-2.5 px-4 rounded-xl whitespace-nowrap no-underline transition-[background-color,opacity] duration-150 ease-linear hover:bg-[var(--color-border)]"
          data-mode="programming"
        >
          <CodeXml size={18} />
          <span class="text-sm font-medium">Programming</span>
        </a>
      </div>
      <div
        class="relative z-2 flex items-center justify-center w-12 h-12 rounded-full shrink-0 cursor-default shadow-[0_4px_20px_rgba(0,0,0,0.15)]"
        id="mode-bubble-icon"
        style="background-color: var(--color-muted); border: 1px solid var(--color-border); color: var(--color-text);"
      >
        <span id="icon-camera" class="hidden items-center justify-center"
          ><Camera size={22} /></span
        >
        <span id="icon-code" class="hidden items-center justify-center"
          ><CodeXml size={22} /></span
        >
      </div>
    </div>

    <main class="pt-4">
      <slot />
    </main>
  </body>
</html>

<script>
  function updateMode() {
    const label = document.getElementById("mode-label");
    const isProgramming = window.location.pathname.startsWith("/programming");
    const currentMode = isProgramming ? "programming" : "photography";

    if (label)
      label.textContent = isProgramming ? "Programming" : "Photography";

    const iconCamera = document.getElementById("icon-camera");
    const iconCode = document.getElementById("icon-code");
    if (iconCamera && iconCode) {
      iconCamera.style.display =
        currentMode === "photography" ? "flex" : "none";
      iconCode.style.display = currentMode === "programming" ? "flex" : "none";
    }

    document.querySelectorAll(".mode-option").forEach((opt) => {
      const el = opt as HTMLElement;
      if (el.dataset.mode === currentMode) {
        el.classList.add("opacity-40", "pointer-events-none");
      } else {
        el.classList.remove("opacity-40", "pointer-events-none");
      }
    });
  }
  document.addEventListener("astro:after-swap", updateMode);
  updateMode();
</script>

<style is:global>
  @import "../styles/global.css";
  @import "../styles/modes/photography.css";
  @import "../styles/modes/programming.css";
  @import "../styles/transitions.css";
</style>
