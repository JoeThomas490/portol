---
import { ClientRouter } from "astro:transitions";

import Favicons from "../components/Favicons.astro";
import ArrowLeft from "@lucide/astro/icons/arrow-left";

interface Props {
  title: string;
  description?: string;
  mode?: "photography" | "programming" | "base" | "about";
}

const navLinks = [
  { name: "Photography", href: "/photography" },
  { name: "Programming", href: "/programming" },
  { name: "About", href: "/about" },
];

const { title, description = "joenoseph", mode = "base" } = Astro.props;

const isLanding = Astro.url.pathname === "/";
---

<!doctype html>
<html lang="en" data-mode={mode !== "base" ? mode : undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <Favicons variant={mode} />
    <title>{title.toLowerCase()} | joenoseph</title>
    <ClientRouter />
  </head>
  <body
    class:list={[
      "min-h-dvh",
      mode === "base" && "bg-neutral-950 text-neutral-300",
    ]}
    style={mode !== "base"
      ? `background-color: var(--color-bg); color: var(--color-text);`
      : undefined}
  >
    <nav transition:animate="none" class="fixed top-0 left-0 right-0 z-50 p-6">
      <div class="flex items-start justify-between">
        <div class="flex flex-col items-start gap-0 text-(--color-text)">
          {
            !isLanding ? (
              <a
                href="#"
                id="back-link"
                class:list={[
                  "flex items-center gap-2 no-underline transition-colors duration-300",
                  mode === "base" ? "text-neutral-400 hover:text-white" : "",
                ]}
                style={
                  mode !== "base" ? "color: var(--color-text);" : undefined
                }
              >
                <ArrowLeft size={18} />
                <span
                  class="text-lg font-bold tracking-tight"
                  style={
                    mode !== "base"
                      ? "color: var(--color-text);"
                      : "color: white;"
                  }
                >
                  joenoseph
                </span>
                <span class="text-lg font-bold text-(--color-accent) -ml-1">
                  {mode}
                </span>
                <span class="text-lg font-bold text-(--color-accent) -ml-1">
                  *
                </span>
              </a>
            ) : (
              <div class="flex items-center gap-0 ml-2">
                <a href="/" class="text-lg font-bold tracking-tight text-white">
                  joenoseph
                </a>
                <span class="text-lg text-white ml-1">*</span>
              </div>
            )
          }
          <!-- {
            mode !== "base" && (
              <span
                class="text-lg font-bold tracking-tight text-orange-400 -mt-2 ml-4"
                id="mode-label"
              >
                {mode}
              </span>
            )
          } -->
        </div>
        <!-- {
          !isLanding && (
            <div class="flex items-start justify-end gap-4">
              {navLinks.map((link) => {
                const Icon = link.icon;
                const isActive = Astro.url.pathname.startsWith(link.href);
                return (
                  <a
                    href={link.href}
                    class:list={[
                      "flex items-center gap-1.5 text-sm font-medium no-underline transition-colors duration-300 bg-green-500/20 rounded-md px-2 py-1",
                      isActive
                        ? "text-green-500"
                        : mode === "base"
                          ? "text-neutral-500 hover:text-white"
                          : "",
                    ]}
                    style={
                      !isActive && mode !== "base"
                        ? "color: var(--color-text); opacity: 0.6;"
                        : undefined
                    }
                  >
                    <span>{link.name}</span>
                  </a>
                );
              })}
            </div>
          )
        } -->
      </div>
    </nav>

    <main class={mode !== "base" ? "pt-4" : ""}>
      <slot />
    </main>
  </body>
</html>

<script>
  document.addEventListener("astro:page-load", () => {
    const backLink = document.getElementById("back-link");
    backLink?.addEventListener("click", (e) => {
      e.preventDefault();
      history.back();
    });
  });
</script>

<style is:global>
  @import "../styles/global.css";
  @import "../styles/modes/photography.css";
  @import "../styles/modes/programming.css";
  @import "../styles/modes/about.css";
</style>
