---
import { ViewTransitions } from "astro:transitions";
import Camera from "@lucide/astro/icons/camera";
import CodeXml from "@lucide/astro/icons/code-xml";

interface Props {
  mode: "photography" | "programming";
}

const { mode } = Astro.props;
---

<!doctype html>
<html lang="en" data-mode={mode}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Joe Thomas" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Developer | Joe Thomas</title>
    <ViewTransitions />
  </head>
  <body
    class="min-h-dvh"
    style={`background-color: var(--color-bg); color: var(--color-text);`}
  >
    <div
      id="mode-bubble"
      transition:persist
      class="group fixed bottom-6 right-6 z-50 flex flex-col items-center"
    >
      <div
        class="flex flex-col gap-0.5 p-1.5 mb-2 rounded-full shadow-[0_4px_20px_rgba(0,0,0,0.15)] origin-bottom invisible scale-y-0 translate-y-2.5 opacity-0 pointer-events-none transition-[opacity,transform,visibility] duration-400 ease-mode group-hover:visible group-hover:scale-y-100 group-hover:translate-y-0 group-hover:opacity-100 group-hover:pointer-events-auto group-hover:delay-0 [transition-delay:0s,0s,0.4s] group-hover:[transition-delay:0s,0s,0s]"
        style="background-color: var(--color-muted); border: 1px solid var(--color-border);"
      >
        <a
          href="/photography"
          data-astro-prefetch="hover"
          class="mode-option flex items-center gap-2.5 py-2.5 px-4 rounded-full whitespace-nowrap no-underline transition-[background-color,opacity] duration-150 ease-linear hover:bg-(--color-invert)"
          data-mode="photography"
        >
          <Camera size={18} />
        </a>
        <a
          href="/programming"
          data-astro-prefetch="hover"
          class="mode-option opacity-40 pointer-events-none flex items-center gap-2.5 py-2.5 px-4 rounded-full whitespace-nowrap no-underline transition-[background-color,opacity] duration-150 ease-linear hover:bg-(--color-invert)"
          data-mode="programming"
        >
          <CodeXml size={18} />
        </a>
      </div>
      <div
        class="relative z-2 flex items-center justify-center w-12 h-12 rounded-full shrink-0 cursor-default shadow-[0_4px_20px_rgba(0,0,0,0.15)]"
        id="mode-bubble-icon"
        style="background-color: var(--color-muted); border: 1px solid var(--color-border); color: var(--color-text);"
      >
        <span id="icon-code" class="items-center justify-center"
          ><CodeXml size={22} /></span
        >
      </div>
    </div>

    <main class="pt-4 max-w-4xl mx-auto px-6">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
  @import "../styles/modes/photography.css";
  @import "../styles/modes/programming.css";
  @import "../styles/transitions.css";
</style>
