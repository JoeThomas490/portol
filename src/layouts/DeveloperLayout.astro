---
import { ViewTransitions } from "astro:transitions";
import ModeBubble from "../components/ModeBubble.astro";

interface Props {
  mode: "photography" | "programming";
}

const { mode } = Astro.props;
---

<!doctype html>
<html lang="en" data-mode={mode}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Joe Thomas" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Developer | Joe Thomas</title>
    <ViewTransitions />
  </head>
  <body
    class="min-h-dvh"
    style={`background-color: var(--color-bg); color: var(--color-text);`}
  >
    <ModeBubble />

    <main class="pt-4 max-w-4xl mx-auto px-6">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
  @import "../styles/modes/photography.css";
  @import "../styles/modes/programming.css";
  @import "../styles/transitions.css";
</style>
