---
interface Props {
  href: string;
  label: string;
  icon?: string;
  class?: string;
}

const { href, label, icon, class: className } = Astro.props;
const isExternal = href.startsWith("http") || href.startsWith("mailto:");
---

<a
  href={href}
  {...isExternal && { target: "_blank", rel: "noopener noreferrer" }}
  class:list={[
    "relative h-8 md:h-12 w-fit min-w-4 md:min-w-12 px-4 rounded-lg bg-white/10 hover:bg-white/20 backdrop-blur-3xl transition-all duration-200 flex items-center justify-center gap-2 font-medium text-sm",
    className,
  ]}
  aria-label={label}
>
  {icon && <img src={icon} alt={label} class="w-4 md:w-6 h-4 md:h-6" />}
  <slot />
</a>
