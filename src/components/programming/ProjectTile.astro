---
import Tag from "@lucide/astro/icons/tag";

interface Props {
  href: string;
  title: string;
  description: string;
  heroImage?: string;
  tags?: string[];
}

const { href, title, description, heroImage, tags = [] } = Astro.props;
---

<a
  href={href}
  class="project-tile group flex flex-col overflow-hidden rounded-2xl border-2 border-white/20 shadow-md hover:shadow-xl hover:border-(--color-accent)/75 transition-all duration-300 select-none"
>
  <div class="relative aspect-square overflow-hidden">
    {
      heroImage && (
        <img
          src={heroImage}
          alt={title}
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 ease-[cubic-bezier(0.25,0,0.2,1)] group-hover:scale-105"
          loading="lazy"
        />
      )
    }
  </div>
  <div class="flex-1 flex flex-col justify-between gap-2 p-4">
    <div class="flex flex-col">
      <h2 class="text-lg md:text-xl font-bold tracking-tight font-heading">
        {title}
      </h2>
      <p class="text-sm text-(--color-text-muted) line-clamp-2">
        {description}
      </p>
    </div>
    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 pt-1">
          <span class="text-sm text-(--color-text-muted) flex flex-row items-center gap-1">
            <Tag class="w-4 h-4" />
          </span>
          {tags.map((tag: string) => (
            <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-(--color-accent)/7 text-(--color-accent)/90 border border-(--color-accent)/20">
              {tag.toLowerCase()}
            </span>
          ))}
        </div>
      )
    }
  </div>
</a>
