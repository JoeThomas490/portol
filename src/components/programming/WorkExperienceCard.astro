---
import ExternalLink from "@lucide/astro/icons/external-link";

interface Props {
  role: string;
  studio: string;
  logo?: string;
  dateRange: string;
  website?: string;
  active?: boolean;
}

const { role, studio, logo, dateRange, website, active = false } = Astro.props;
---

<div
  class="flex flex-col sm:flex-row gap-4 p-5 rounded-2xl border-2 border-white/20 hover:border-purple-500/40 transition-colors duration-300"
>
  {
    logo && (
      <div class="shrink-0 flex items-start justify-center pt-1">
        <img
          src={logo}
          alt={`${studio} logo`}
          class="w-12 h-12 rounded-lg object-contain bg-white/10 p-1.5"
          loading="lazy"
        />
      </div>
    )
  }

  <div class="flex-1 flex flex-col gap-1.5">
    <div
      class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1"
    >
      <div>
        <h3 class="text-lg font-bold font-heading leading-tight">{role}</h3>
        <div class="flex items-center gap-1.5">
          {
            website ? (
              <a
                href={website}
                target="_blank"
                rel="noopener noreferrer"
                class="text-(--color-accent) hover:text-(--color-accent)/80 font-medium text-sm flex items-center gap-1 transition-colors"
              >
                {studio}
                <ExternalLink class="w-3.5 h-3.5" />
              </a>
            ) : (
              <span class="text-(--color-accent) font-medium text-sm">
                {studio}
              </span>
            )
          }
        </div>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        {
          active && (
            <span class="flex items-center gap-1.5 px-2 py-0.5 text-xs font-medium rounded-full bg-green-500/10 text-green-400 border border-green-500/20">
              <span class="relative flex h-2 w-2">
                <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500" />
              </span>
              Active
            </span>
          )
        }
        <span class="text-xs text-(--color-text-muted) whitespace-nowrap">
          {dateRange}
        </span>
      </div>
    </div>

    <div
      class="mt-2 text-sm text-(--color-text-muted) leading-relaxed [&>ul]:list-disc [&>ul]:pl-4 [&>ul]:space-y-1 px-4 pr-24"
    >
      <slot />
    </div>
  </div>
</div>
